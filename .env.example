# Application
APP_NAME=boilerworks-fastapi-micro
DEBUG=true

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/boilerworks

# Redis (optional)
REDIS_URL=redis://localhost:6379/0

# Rate Limiting
RATE_LIMIT_DEFAULT=100/minute

# Admin bootstrap key (only used on first run to create the initial API key)
ADMIN_BOOTSTRAP_KEY=
